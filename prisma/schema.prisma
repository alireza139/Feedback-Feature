generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}
enum FeedbackStatus {
  SUBMITTED
  REVIEWING
  RESOLVED
}

model Feedback {
  id        Int            @id @default(autoincrement())
  title     String
  message   String         @db.Text
  status    FeedbackStatus @default(SUBMITTED)
  createdAt DateTime       @default(now())
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}
